# Create a Web3Forms access key at https://web3forms.com/
VITE_WEB3FORMS_ACCESS_KEY=replace_with_your_access_key
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=replace_with_your_access_key

# WordPress.com headless blog API.
# Example: https://public-api.wordpress.com/wp/v2/sites/your-site.wordpress.com
VITE_WORDPRESS_API_BASE=https://public-api.wordpress.com/wp/v2/sites/your-site.wordpress.com
WORDPRESS_API_BASE=https://public-api.wordpress.com/wp/v2/sites/your-site.wordpress.com
NEXT_PUBLIC_WORDPRESS_API_BASE=https://public-api.wordpress.com/wp/v2/sites/your-site.wordpress.com

# Optional local preview mode for sample blog cards/posts.
VITE_WORDPRESS_DEMO=false

# Used by /api/revalidate so WordPress/webhooks can refresh blog pages without a full build.
REVALIDATION_SECRET=replace_with_a_long_random_secret
